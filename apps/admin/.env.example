# Copy to .env and set values. See README for full setup.

# DataForSEO (GBP scraping) — from https://app.dataforseo.com/api-access
# When set, demo creation uses real Google Business Profile data; otherwise falls back to Gemini.
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# DATAFORSEO_DEFAULT_LOCATION=Toronto,Ontario,Canada
# DATAFORSEO_DEFAULT_LANGUAGE_CODE=en

# Resend (email sending)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_FROM_NAME=Lead Rosetta

# Google OAuth (dashboard sign-in — direct OAuth; callback /auth/callback)
# Create OAuth client in Google Cloud; Web application; redirect URI = {your origin}/auth/callback
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# (aliases: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET)
# Optional: if the app’s public URL differs from what the server sees (proxy), set full callback URL:
# AUTH_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback
# SESSION_SECRET=   # required: 16+ chars; signs the admin session cookie

# Supabase (DB, service role, Realtime JWT sync via signInWithIdToken — enable Google provider in Supabase)
# Option A — recommended for Vite/client: public vars (same URL and anon key from Dashboard → API)
# PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_ANON_KEY=
# Option B — if you already use server vars only, add anon key here; hooks/layout fall back from these:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# Server-only (cron, admin writes; bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: PostgREST schema for table/RPC calls from the server (default public). Use dev for a parallel dev schema.
# SUPABASE_DB_SCHEMA=public
# Optional: direct Postgres URI for `pnpm run db:push:dev` only (Dashboard → Database). Not the same as SUPABASE_URL (HTTPS API).
# SUPABASE_DATABASE_URL=

# Gemini (AI audit when DataForSEO not used or fails)
# GEMINI_API_KEY=

# Google Stitch (per-user OAuth on Integrations — demo HTML via apps/stitch)
# Create OAuth client (Web app); redirect URI = {origin}/auth/stitch/callback
# Enable stitch.googleapis.com on the GCP project; consent screen: cloud-platform + userinfo.email
# Grant staff users roles/serviceusage.serviceUsageConsumer on the project (see plan / docs).
# STITCH_GOOGLE_CLIENT_ID=
# STITCH_GOOGLE_CLIENT_SECRET=
# GCP project ID used by Stitch MCP when calling with OAuth (same project where Stitch API is enabled).
# STITCH_GOOGLE_CLOUD_PROJECT=

# External demo generator (apps/stitch on Render) — async POST + callback
# DEMO_GENERATOR_URL=
# DEMO_GENERATOR_API_KEY=
# DEMO_CALLBACK_SECRET=

# Apify (Google Maps / Places scraper for Prospects → Import from Apify)
# APIFY_API_TOKEN=
