# Required: Google Stitch API key (@google/stitch-sdk)
STITCH_API_KEY=

# Optional: bare project id if list_projects does not return a matchable title
# STITCH_LAUNCH_ROSETTA_PROJECT_ID=

# Optional: cap successful Stitch generations per UTC day (default 100). Set 0 to disable.
# STITCH_DAILY_GENERATION_LIMIT=100
# Optional: override path for the local quota state file (default: .stitch/daily-generation-state.json under cwd)
# STITCH_DAILY_GENERATION_STATE_FILE=

# POST /api/create-async (Ed & Sy Admin demo generator): Bearer auth — use same value as admin DEMO_GENERATOR_API_KEY
# DEMO_GENERATOR_API_KEY=
# alias: STITCH_DEMO_GENERATOR_API_KEY=

# Supabase Storage: upload demo-html/{prospectId}.html (same bucket as admin)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# DEMO_HTML_BUCKET=admin-ednsy-bucket

# Optional: restrict callbackUrl origins (comma-separated), e.g. https://admin.example.com
# ALLOWED_CALLBACK_ORIGINS=
