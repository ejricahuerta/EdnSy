# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: API server port (default 3000)
# PORT=3000

# Optional: for uploading to Supabase Storage (demo-html/{id}.html). Same names as apps/admin:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: PostgREST schema (default public). Match apps/admin when using a dev schema.
# SUPABASE_DB_SCHEMA=public
# In the monorepo, generate.js also loads ../admin/.env first so you can define Supabase only there.
